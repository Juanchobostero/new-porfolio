---
---

<div id="whatsapp-widget">
  <!-- Botón flotante -->
  <button
    id="whatsapp-button"
    aria-label="Abrir chat de WhatsApp"
    class="fixed bottom-6 right-6 w-14 h-14 bg-green-500 hover:bg-green-600 rounded-full shadow-lg hover:shadow-2xl transition-all duration-300 flex items-center justify-center text-white z-50 hover:scale-110 group"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="white"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="group-hover:rotate-12 transition-transform duration-300 relative z-10"
    >
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
    </svg>
    <span class="absolute inset-0 rounded-full bg-green-500/20 group-hover:bg-green-500/10 transition-all duration-300 pointer-events-none" aria-hidden="true"></span>
  </button>

  <!-- Modal de chat -->
  <div
    id="whatsapp-modal"
    class="fixed bottom-24 right-6 w-96 h-96 bg-white rounded-xl shadow-2xl hidden z-50 flex flex-col transition-all duration-300 overflow-hidden"
  >
    <!-- Header del chat -->
    <div class="bg-green-500 text-white p-4 rounded-t-lg flex items-center gap-3">
      <img
        src="/photo.webp"
        alt="Foto de perfil - Juan Cruz Martínez"
        class="w-10 h-10 rounded-full object-cover border-2 border-white"
      />
      <div class="flex-1">
        <h3 class="font-bold text-sm">Juan Cruz Martínez</h3>
        <p class="text-xs text-green-100">Típicamente responde en minutos</p>
      </div>
      <button
        id="close-chat"
        aria-label="Cerrar chat"
        class="hover:bg-green-600 rounded p-1 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Área de mensajes -->
    <div class="flex-1 overflow-y-auto p-4 bg-gray-50 space-y-3">
      <div class="flex justify-start">
        <div class="bg-gray-200 text-gray-800 rounded-lg rounded-tl-none px-3 py-2 max-w-xs text-sm">
          Hola 👋 ¿Cómo estás?
        </div>
      </div>
      <div class="flex justify-start">
        <div class="bg-gray-200 text-gray-800 rounded-lg rounded-tl-none px-3 py-2 max-w-xs text-sm">
          En que puedo ayudarte?
        </div>
      </div>
    </div>

    <!-- Input de mensaje -->
    <div class="border-t border-gray-200 p-3 flex gap-2">
      <input
        id="whatsapp-input"
        type="text"
        placeholder="Escribe tu mensaje..."
        class="flex-1 border border-gray-300 rounded-full px-4 py-2 text-sm focus:outline-none focus:border-green-500 transition-colors"
      />
      <a
        id="send-whatsapp"
        href="https://wa.me/543794065380?text="
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Enviar mensaje por WhatsApp"
        class="bg-green-500 hover:bg-green-600 text-white rounded-full p-2 transition-colors flex items-center justify-center"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </a>
    </div>
  </div>
</div>

<style>
  #whatsapp-modal.active {
    @apply block;
    animation: slideUp 0.3s ease-out;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const whatsappButton = document.getElementById('whatsapp-button');
    const whatsappModal = document.getElementById('whatsapp-modal');
    const closeButton = document.getElementById('close-chat');
    const whatsappInput = document.getElementById('whatsapp-input') as HTMLInputElement;
    const sendButton = document.getElementById('send-whatsapp');

    // Cambiar número de WhatsApp aquí
    const WHATSAPP_NUMBER = '543794065380'; // Reemplaza con tu número

    // Toggle del modal
    whatsappButton?.addEventListener('click', () => {
      whatsappModal?.classList.toggle('active');
      if (whatsappModal?.classList.contains('active')) {
        whatsappInput?.focus();
      }
    });

    // Cerrar modal
    closeButton?.addEventListener('click', () => {
      whatsappModal?.classList.remove('active');
    });

    // Cerrar al hacer click fuera
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (
        !target.closest('#whatsapp-widget') &&
        whatsappModal?.classList.contains('active')
      ) {
        whatsappModal.classList.remove('active');
      }
    });

    // Enviar mensaje por WhatsApp
    whatsappInput?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        const message = whatsappInput.value.trim();
        if (message) {
          const encodedMessage = encodeURIComponent(message);
          const whatsappUrl = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodedMessage}`;
          window.open(whatsappUrl, '_blank');
          whatsappInput.value = '';
          whatsappModal?.classList.remove('active');
        }
      }
    });

    // Actualizar link al cambiar el input
    whatsappInput?.addEventListener('input', (e) => {
      const message = (e.target as HTMLInputElement).value.trim();
      if (message) {
        const encodedMessage = encodeURIComponent(message);
        sendButton?.setAttribute(
          'href',
          `https://wa.me/${WHATSAPP_NUMBER}?text=${encodedMessage}`
        );
      }
    });

    // Click en botón de envío
    sendButton?.addEventListener('click', (e) => {
      const message = whatsappInput?.value.trim();
      if (!message) {
        e.preventDefault();
      } else {
        whatsappInput!.value = '';
        setTimeout(() => {
          whatsappModal?.classList.remove('active');
        }, 300);
      }
    });
  });
</script>
