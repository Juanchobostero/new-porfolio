---
import SocialPill from "./SocialPill.astro";
import Mail from "./icons/Mail.astro";
---

<section id="contacto" class="flex flex-row md:flex-row gap-8 justify-start m-1">
    <div class="p-1 flex flex-row gap-2">
        <h2 class="text-2xl"><span class="text-sky-400 font-bold">¿Tenés un Proyecto? </span><span class="text-gray-100">Trabajemos juntos.</span></h2>
        &nbsp;&nbsp;
        <SocialPill href="mailto:juancruzmart93@gmail.com" aria-label="Contacto por email: juancruzmart93@gmail.com">
            <Mail class="size-4 md:size-6" aria-hidden="true"/>
            	Contactame
        </SocialPill>
    </div>
</section>

<style>
    @keyframes reveal {
		from {
			opacity: 0;
			transform: 0 100px;
		}
		to {
			opacity: 1;
			transform: 0 0;
		}
	}

	section {
		animation: reveal both;
		animation-timeline: view();
		animation-range: entry 20% cover 30%;
	}
</style>