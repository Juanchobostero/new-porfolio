---
const { href } = Astro.props
---

<a
  href={href}
  class="bg-white/5
    border dark:border-white/10 border-gray-300
    rounded-lg
    inline-flex justify-center items-center gap-x-2
    py-2 px-4 md:py-2.5 md:px-5
    text-xs md:text-base
    transition-all duration-300 ease-out
    hover:scale-105 hover:bg-white/15 hover:border-sky-400/60 hover:shadow-lg hover:shadow-sky-500/30 hover:-translate-y-0.5
    active:scale-95 active:bg-white/10"
    rel="noopener noreferrer" 
    target="_blank"
>
  <slot />
</a>
