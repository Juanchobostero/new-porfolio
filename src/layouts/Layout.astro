---
// Supports weights 100-900
import '@fontsource/space-mono';
import '@fontsource/source-sans-pro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import GitHubFloatingButton from '../components/GitHubFloatingButton.astro'
import WhatsAppChat from '../components/WhatsAppChat.astro'
import { ViewTransitions } from 'astro:transitions'
import { injectSpeedInsights } from "@vercel/speed-insights";

interface Props {
	title: string;
	description: string;
	image?: string;
	keywords?: string;
}

const { title, description, image = '/photo.png', keywords = 'desarrollador web, full stack developer, programador Argentina, .NET, CodeIgniter, Node.js, React, desarrollo web' } = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(image, Astro.site);

---

<!doctype html>
<html lang="es" class="min-h-screen">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Preload critical fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="author" content="Juan Cruz Martínez" />
		<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
		<meta name="googlebot" content="index, follow" />
		<meta name="bingbot" content="index, follow" />
		<meta name="revisit-after" content="7 days" />
		<meta name="language" content="es-AR" />
		<meta name="audience" content="all" />
		<link rel="canonical" href={canonicalURL} />
		<link rel="alternate" hreflang="es-AR" href={canonicalURL} />
		<link rel="alternate" hreflang="es" href={canonicalURL} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={socialImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Juan Cruz Martínez - Full Stack Developer" />
		<meta property="og:locale" content="es_AR" />
		<meta property="og:site_name" content="Juan Cruz Martínez - Software Engineer" />
		
		<!-- Twitter / X -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImage} />
		<meta name="twitter:creator" content="@_juancruzmartinez" />
		<meta name="twitter:site" content="@_juancruzmartinez" />
		
		<!-- Favicon -->
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/webp" sizes="32x32" href="/photo.webp" />
		<link rel="icon" type="image/webp" sizes="192x192" href="/photo.webp" />
		<link rel="apple-touch-icon" sizes="180x180" href="/photo.webp" />
		<meta name="theme-color" content="#0f172a" />
		
		<!-- Humans -->
		<link rel="author" href="/humans.txt" />
		
		<!-- External Resources -->
		<link
			rel="stylesheet"
			href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"
		/>
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
		
		<!-- Structured Data (JSON-LD) -->
		<script is:inline type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Person",
				"name": "Juan Cruz Martínez",
				"alternateName": ["Juan Martínez", "Juancho Developer"],
				"url": "https://jotadev.com.ar",
				"jobTitle": "Full Stack Web Developer",
				"description": "Full Stack Web Developer con +6 años de experiencia. Especializado en .NET, CodeIgniter y Node.js.",
				"image": "https://jotadev.com.ar/photo.png",
				"email": "mailto:juancruzmart93@gmail.com",
				"telephone": "+54",
				"address": {
					"@type": "PostalAddress",
					"streetAddress": "Corrientes",
					"addressLocality": "Corrientes Capital",
					"addressRegion": "Corrientes",
					"postalCode": "3400",
					"addressCountry": "AR"
				},
				"sameAs": [
					"https://www.linkedin.com/in/martinezjc93/",
					"https://github.com/Juanchobostero",
					"https://twitter.com/_juancruzmartinez"
				],
				"alumniOf": [{
					"@type": "EducationalOrganization",
					"name": "Universidad Nacional del Nordeste",
					"url": "https://www.unne.edu.ar/",
					"location": {
						"@type": "Place",
						"name": "Corrientes, Argentina"
					}
				}],
				"knowsAbout": [
					".NET",
					"CodeIgniter",
					"Node.js",
					"React",
					"JavaScript",
					"TypeScript",
					"Vue.js",
					"NestJS",
					"Full Stack Development",
					"Web Development",
					"PostgreSQL",
					"MongoDB",
					"MySQL"
				],
				"hasOccupation": [{
					"@type": "Occupation",
					"name": "Full Stack Developer",
					"description": "Desarrollo de aplicaciones web completas con tecnologías modernas",
					"experienceRequirements": {
						"@type": "Text",
						"text": "+6 años de experiencia"
					}
				}],
				"workLocation": {
					"@type": "Place",
					"name": "Remoto"
				}
			}
		</script>
		
		<ViewTransitions />
		{injectSpeedInsights()}
	</head>
	<body class="relative min-h-screen">
		<!-- Gradiente de fondo -->
		<div class="absolute top-0 z-[-2] w-full min-h-full bg-neutral-950 bg-[radial-gradient(ellipse_60%_60%_at_50%_-20%,rgba(80,180,255,0.3),rgba(255,255,255,0))]"></div>
		<!-- Botón de ir arriba -->
	<button class="fixed bottom-6 right-24 w-14 h-14 bg-yellow-400 hover:bg-yellow-500 rounded-full shadow-lg hover:shadow-2xl transition-all duration-300 flex items-center justify-center text-black z-50 hover:scale-110" id="myBtn" title="Ir arriba" aria-label="Volver arriba">
		<i class="fas fa-arrow-up text-lg" aria-hidden="true"></i>
	</button>
	
		<Header />
		<GitHubFloatingButton />
		<WhatsAppChat />
			<slot />
		<Footer />
	</body>
</html>
<style is:global>
	:root {
		color-scheme: dark;
	}
	html {
		font-family: 'Source Sans Pro', sans-serif;
		letter-spacing: 0.05em;
		scroll-behavior: smooth;
		font-size: 16px;
	}

	body {
		line-height: 1.6;
		color: #e5e7eb;
	}

	html, body {
    height: auto;
    min-height: 100vh;
    background-attachment: fixed; /* Hace que el fondo no se corte */
    background-repeat: no-repeat;
    background-size: cover; /* Asegura que el fondo cubra todo */
}

	#myBtn {
		display: none; /* Hidden by default */
		width: 48px;
		height: 48px;
		z-index: 99; /* Make sure it does not overlap */
		border: none; /* Remove borders */
		outline: none; /* Remove outline */
		cursor: pointer; /* Add a mouse pointer on hover */
		transition: all 300ms cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	#myBtn:hover {
		transform: translateY(-3px) scale(1.08);
		box-shadow: 0 12px 24px rgba(250, 204, 21, 0.4);
	}

	#myBtn:active {
		transform: translateY(-1px) scale(1.05);
	}

	@media (prefers-reduced-motion: reduce) {
		html {
			scroll-behavior: auto;
		}
	}
	
</style>

<script>
    // Definir la función topFunction() antes de que se intente llamar desde el evento onclick
    function topFunction() {
        document.body.scrollTop = 0; // For Safari
        document.documentElement.scrollTop = 0; // For Chrome, Firefox, IE and Opera
    }

    // Get the button:
    let mybutton = document.getElementById("myBtn");

    // Check if the button exists before trying to access it
    if (mybutton) {
        // When the user scrolls down 20px from the top of the document, show the button
        window.onscroll = function() {scrollFunction()};
		mybutton.addEventListener("click", topFunction);
    }

    function scrollFunction() {
        if (mybutton && (document.body.scrollTop > 20 || document.documentElement.scrollTop > 20)) {
            mybutton.style.display = "block";
        } else if (mybutton) {
            mybutton.style.display = "none";
        }
    }
</script>

<script>
    import { inject } from "@vercel/analytics";
    inject()
</script>
